      "id": "795ae134-2bd3-4606-934d-37aca8dbc46c",
      "name": "Code in JavaScript1"
    },
    {
      "parameters": {
        "jsCode": "const subject = ($('Gmail Trigger').item.json.subject || '').toLowerCase();\nconst invoiceKeywords = ['invoice', 'inv-', 'inv ', 'bill', 'receipt', 'payment', 'tax invoice'];\nconst isInvoice = invoiceKeywords.some(k => subject.includes(k));\nif (!isInvoice) {\n  throw new Error('SKIP - Not an invoice email: ' + subject);\n}\nconst data = $('Edit Fields').item.json;\n\nconst requiredFields = [\n  'invoice_number',\n  'invoice_date',\n  'seller_name',\n  'seller_address',\n  'buyer_name',\n  'buyer_address',\n  'grand_total',\n  'currency',\n  'gst_tax_amount',\n  'payment_terms',\n  'tracking_number',\n  'carrier_name',\n  'incoterms'\n];\n\nconst missing = [];\nconst errors = [];\nconst missingDetails = [];\nconst errorDetails = [];\n\nfor (const field of requiredFields) {\n  const val = data[field];\n\n  // Check missing\n  if (!val || val === '' || val === null || val === 'null' || val === 'N/A') {\n    missing.push(field);\n    missingDetails.push(`\"${field}\" is missing — no value found`);\n    continue;\n  }\n\n  // Check wrong values\n  if (field === 'invoice_date') {\n    const dateRegex = /^\\d{2}-\\d{2}-\\d{4}$/;\n    if (!dateRegex.test(val)) {\n      errors.push(field);\n      errorDetails.push(`\"invoice_date\" has wrong value \"${val}\" — expected format DD-MM-YYYY (e.g. 24-04-2026)`);\n    }\n  }\n\n  if (field === 'grand_total') {\n    if (isNaN(Number(val)) || Number(val) <= 0) {\n      errors.push(field);\n      errorDetails.push(`\"grand_total\" has wrong value \"${val}\" — must be a positive number (e.g. 234112)`);\n    }\n  }\n\n  if (field === 'gst_tax_amount') {\n    if (isNaN(Number(val)) || Number(val) < 0) {\n      errors.push(field);\n      errorDetails.push(`\"gst_tax_amount\" has wrong value \"${val}\" — must be a number (e.g. 35712)`);\n    }\n  }\n\n  if (field === 'currency') {\n    const validCurrencies = ['INR', 'USD', 'EUR', 'GBP', 'AED'];\n    if (!validCurrencies.includes(val.toUpperCase())) {\n      errors.push(field);\n      errorDetails.push(`\"currency\" has wrong value \"${val}\" — must be one of: INR, USD, EUR, GBP, AED`);\n    }\n  }\n\n  if (field === 'invoice_number') {\n    if (val.length < 3) {\n      errors.push(field);\n      errorDetails.push(`\"invoice_number\" has wrong value \"${val}\" — too short, must be at least 3 characters`);\n    }\n  }\n\n  if (field === 'payment_terms') {\n    const validTerms = ['net 15 days', 'net 30 days', 'net 45 days', 'net 60 days', 'immediate', 'advance'];\n    if (!validTerms.includes(val.toLowerCase())) {\n      errors.push(field);\n      errorDetails.push(`\"payment_terms\" has wrong value \"${val}\" — expected: Net 15 Days, Net 30 Days, Net 45 Days etc.`);\n    }\n  }\n}\n\n// Determine status\nlet status = '';\nlet is_valid = false;\n\nif (missing.length === 0 && errors.length === 0) {\n  status = 'Complete — All fields present and valid';\n  is_valid = true;\n} else if (missing.length > 0 && errors.length === 0) {\n  status = 'Incomplete — ' + missing.length + ' field(s) missing: ' + missing.join(', ');\n  is_valid = false;\n} else if (missing.length === 0 && errors.length > 0) {\n  status = 'Error — ' + errors.length + ' field(s) have wrong values: ' + errors.join(', ');\n  is_valid = false;\n} else {\n  status = 'Incomplete + Error — Missing: ' + missing.join(', ') + ' | Wrong values: ' + errors.join(', ');\n  is_valid = false;\n}\n\n// Full detail report\nconst fullReport = [\n  ...missingDetails,\n  ...errorDetails\n].join('\\n');\n\nreturn [{\n  json: {\n    ...data,\n    is_valid          : is_valid,\n    status            : status,\n    missing_fields    : missing.length > 0 ? missing.join(', ') : 'None',\n    missing_details   : missingDetails.length > 0 ? missingDetails.join('\\n') : 'None',\n    error_fields      : errors.length > 0 ? errors.join(', ') : 'None',\n    error_details     : errorDetails.length > 0 ? errorDetails.join('\\n') : 'None',\n    full_report       : fullReport.length > 0 ? fullReport : 'All fields complete and valid'\n  }\n}];"
      },
