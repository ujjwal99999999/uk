    {
      "parameters": {
        "jsCode": "const data = $('If').item.json;\n\nconst missingList = data.missing_fields !== 'None' \n  ? data.missing_fields.split(',').map(f => '• ' + f.trim()).join('\\n')\n  : '';\n\nconst errorList = data.error_fields !== 'None'\n  ? data.error_fields.split(',').map(f => '• ' + f.trim()).join('\\n')\n  : '';\n\nlet issueSection = '';\nif (missingList) {\n  issueSection += `Missing Fields:\\n${missingList}\\n\\n`;\n}\nif (errorList) {\n  issueSection += `Invalid Fields:\\n${errorList}\\n\\n`;\n}\n\nconst emailBody = `Dear ${data.seller_name || 'Supplier'},\n\nThank you for sending your invoice (${data.invoice_number || 'N/A'}).\n\nWe have reviewed the document and found the following issues that need to be corrected before we can process payment:\n\n${issueSection}Please resend the corrected invoice at your earliest convenience.\n\nIf you have any questions, please feel free to contact us.\n\nRegards,\nDelta Exports Ltd\nAccounts Payable Team`;\n\nreturn [{\n  json: {\n    ...data,\n    email_body      : emailBody,\n    email_subject   : `Action Required — Invoice ${data.invoice_number || 'N/A'} — Missing/Invalid Fields`,\n    missing_fields  : data.missing_fields || 'None',\n    missing_details : data.missing_details || 'None',\n    error_fields    : data.error_fields || 'None',\n    error_details   : data.error_details || 'None',\n    status          : data.status || 'Incomplete',\n    full_report     : data.full_report || 'None'\n  }\n}];"
      },
