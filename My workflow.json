    {
      "parameters": {
        "jsCode": "const data = $('If').item.json;\n\nconst fields = [\n  'invoice_number',\n  'invoice_date',\n  'seller_name',\n  'seller_address',\n  'buyer_name',\n  'buyer_address',\n  'grand_total',\n  'currency',\n  'gst_tax_amount',\n  'payment_terms',\n  'tracking_number',\n  'carrier_name',\n  'incoterms'\n];\n\nconst missing = [];\n\nfor (const field of fields) {\n  const val = data[field];\n  if (!val || val === '' || val === null || val === 'null' || val === 'N/A') {\n    missing.push(field);\n  }\n}\n\nconst missingText = missing.length === 0 ? 'None' : missing.join(', ');\nconst status = missing.length === 0 ? 'Complete' : 'Incomplete';\n\nreturn [{\n  json: {\n    invoice_number: data.invoice_number || 'N/A',\n    invoice_date: data.invoice_date || 'N/A',\n    seller_name: data.seller_name || 'N/A',\n    buyer_name: data.buyer_name || 'N/A',\n    grand_total: data.grand_total || 'N/A',\n    currency: data.currency || 'N/A',\n    gst_tax_amount: data.gst_tax_amount || 'N/A',\n    payment_terms: data.payment_terms || 'N/A',\n    tracking_number: data.tracking_number || 'N/A',\n    carrier_name: data.carrier_name || 'N/A',\n    incoterms: data.incoterms || 'N/A',\n    status: status,\n    missing_fields: missingText\n  }\n}];"
      },
