        "jsCode": "const data = $('If').item.json;\n\nconst fields = [\n  'invoice_number',\n  'invoice_date',\n  'seller_name',\n  'seller_address',\n  'buyer_name',\n  'buyer_address',\n  'grand_total',\n  'currency',\n  'gst_tax_amount',\n  'payment_terms',\n  'tracking_number',\n  'carrier_name',\n  'incoterms'\n];\n\nconst missing = [];\n\nfor (const field of fields) {\n  const val = data[field];\n  if (!val || val === '' || val === null || val === 'null' || val === 'N/A') {\n    missing.push(field);\n  }\n}\n\nconst missingText = missing.join(', ');\n\nconst emailBody = `Dear ${data.seller_name || 'Sender'},\n\nThank you for sending your invoice.\n\nWe reviewed invoice ${data.invoice_number || 'N/A'} and found the following fields are missing:\n\nMissing Fields: ${missingText}\n\nPlease resend the complete invoice with above information.\n\nRegards,\nInvoice Processing Team`;\n\nconst telegramMsg = `Invoice Alert - Fields Missing!\n\nInvoice No : ${data.invoice_number || 'N/A'}\nDate       : ${data.invoice_date || 'N/A'}\nSeller     : ${data.seller_name || 'N/A'}\nBuyer      : ${data.buyer_name || 'N/A'}\nAmount     : ${data.grand_total || 'N/A'} ${data.currency || ''}\nStatus     : Incomplete\nMissing    : ${missingText}`;\n\nreturn [{\n  json: {\n    invoice_number  : data.invoice_number  || 'N/A',\n    invoice_date    : data.invoice_date    || 'N/A',\n    seller_name     : data.seller_name     || 'N/A',\n    buyer_name      : data.buyer_name      || 'N/A',\n    grand_total     : data.grand_total     || 'N/A',\n    currency        : data.currency        || 'N/A',\n    gst_tax_amount  : data.gst_tax_amount  || 'N/A',\n    payment_terms   : data.payment_terms   || 'N/A',\n    tracking_number : data.tracking_number || 'N/A',\n    carrier_name    : data.carrier_name    || 'N/A',\n    incoterms       : data.incoterms       || 'N/A',\n    status          : 'Incomplete',\n    missing_fields  : missingText,\n    email_body      : emailBody,\n    telegram_msg    : telegramMsg\n  }\n}];"
      },
